# Production .env for the current SwoiVPN bot architecture.
# Fill every CHANGE_ME value before deploy.
# Do not commit this file with real secrets.

# =========================
# Core app / database
# =========================
BOT_TOKEN=8745973983:AAGgaXSYVJzLSO2LgLW*******gfGMI0U

POSTGRES_USER=vpn_service_db
POSTGRES_DB=vpn_bot
POSTGRES_PASSWORD=Gjcnuh****3Lfnf
DATABASE_URL=postgresql+asyncpg://vpn_service_db:Gjcnuh****3Lfnf@postgres:5432/vpn_bot

# =========================
# Telegram / app identity
# =========================
SERVICE_NAME=SwoiVPN
BOT_USERNAME=swoi_vpn_bot
ADMIN_IDS=[]
SUPPORT_IDS=[]
STARTUP_NOTIFY_IDS=[]
SUPPORT_CHAT_ID=-1001234567890
TELEGRAM_PROXY_URL=

# =========================
# Timezones
# =========================
UI_TIMEZONE=Europe/Moscow
DB_TIMEZONE=UTC

# =========================
# Public web surface
# bot.svoivpn.xyz -> webhook/callback/payment pages
# panel.svoivpn.xyz -> only /sub/<token>
# =========================
WEBHOOK_ENABLED=true
WEBHOOK_BASE_URL=https://bot.svoivpn.xyz
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=3e7293175c670027b091c55376f77dc8ecc0cb10abf42145c397200*****2f

APP_HOST=0.0.0.0
APP_PORT=8080

# =========================
# Web admin (local-only)
# Open only via SSH tunnel, for example:
# ssh -L 8001:127.0.0.1:8001 user@server
# =========================
WEB_ADMIN_HOST=127.0.0.1
WEB_ADMIN_PORT=8001
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=8ecc0cb10abf****5c39
WEB_ADMIN_LOCAL_ONLY=true
WEB_ADMIN_ALLOWED_IPS=["127.0.0.1","::1"]
WEB_ADMIN_TRUST_FORWARDED_HEADERS=false
WEB_ADMIN_FORWARDED_FOR_HEADER=X-Forwarded-For
# Uncomment only if you ever put admin behind nginx/reverse proxy and also set
# WEB_ADMIN_TRUST_FORWARDED_HEADERS=true
# WEB_ADMIN_ALLOWED_PROXY_IPS=127.0.0.1/32,::1/128

# =========================
# Payments (Platega)
# Public success/failed pages are exposed by nginx on bot.svoivpn.xyz
# and internally proxied to the local FastAPI app on 127.0.0.1:8001.
# =========================
PAYMENT_PROVIDER=platega
PAYMENT_SUCCESS_DELAY_SECONDS=2
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=e6157015-e7e9-48be-b65e-1bb******dc
PLATEGA_SECRET=78sYe96yhCuqK94sO06Ywu6ivyffIA166TVICkByDZgA0ECILA7DViw4CRcZzk1SYaUxRRD9*******3iaMbYn5AFKHSS
PLATEGA_PAYMENT_METHOD=2
PLATEGA_CURRENCY=RUB
PLATEGA_RETURN_URL=https://bot.svoivpn.xyz/payment/success
PLATEGA_FAILED_URL=https://bot.svoivpn.xyz/payment/failed
PLATEGA_TIMEOUT_SECONDS=20
PLATEGA_CALLBACK_PATH=/callbacks/platega/payment-status

# =========================
# Marzban / Xray
# API is internal; public subscription page lives on panel.svoivpn.xyz only.
# If Marzban runs on the same server in host network, 127.0.0.1:8000 is correct.
# =========================
MARZBAN_ENABLED=true
MARZBAN_API_BASE_URL=http://127.0.0.1:8000
MARZBAN_SUBSCRIPTION_BASE_URL=https://panel.svoivpn.xyz
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=marzban_panel_***_123
MARZBAN_VLESS_INBOUNDS=["VLESS XHTTP REALITY DK1"]
MARZBAN_STATUS_ON_CREATE=active
MARZBAN_ONLINE_LIMIT_FIELD=onlinelimit
MARZBAN_REQUEST_TIMEOUT_SECONDS=20
MARZBAN_REQUEST_RETRIES=2
MARZBAN_TOKEN_TTL_SECONDS=300
MARZBAN_ENV_FILE_PATH=/opt/marzban/.env
MARZBAN_MANAGED_ENV_ALLOWLIST=["XRAY_SUBSCRIPTION_URL_PREFIX","XRAY_FALLBACK_DNS","XRAY_GEOIP_PATH","XRAY_GEOSITE_PATH","UVICORN_FORWARDED_ALLOW_IPS","DOCS","REDOC"]
MARZBAN_MANAGED_ENV_READONLY_KEYS=["SQLALCHEMY_DATABASE_URL","POSTGRES_PASSWORD","JWT_SECRET_KEY","SUDO_USERNAME","SUDO_PASSWORD"]

# =========================
# Geodata
# =========================
GEODATA_UPDATE_ENABLED=true
GEODATA_AUTO_UPDATE_ON_STARTUP=false
GEODATA_ASSETS_DIR=/opt/marzban/assets
GEODATA_GEOIP_FILENAME=geoip.dat
GEODATA_GEOSITE_FILENAME=geosite.dat
GEODATA_GEOIP_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat
GEODATA_GEOSITE_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat
GEODATA_GEOIP_SHA256_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat.sha256sum
GEODATA_GEOSITE_SHA256_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat.sha256sum
GEODATA_REQUEST_TIMEOUT_SECONDS=60
GEODATA_CHECK_INTERVAL_HOURS=24
GEODATA_RETAINED_BACKUPS=2

# =========================
# Logging / metrics / sentry
# =========================
LOG_LEVEL=INFO
LOG_DIR=logs
METRICS_ENABLED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# =========================
# Anti-spam / cache / scheduler / broadcasts
# =========================
ANTI_SPAM_ENABLED=true
ANTI_SPAM_MESSAGE_LIMIT=10
ANTI_SPAM_MESSAGE_WINDOW_SECONDS=12
ANTI_SPAM_CALLBACK_LIMIT=12
ANTI_SPAM_CALLBACK_WINDOW_SECONDS=8
ANTI_SPAM_BLOCK_SECONDS=10
ANTI_SPAM_MIN_INTERVAL_SECONDS=0.5
ANTI_SPAM_SETTINGS_CACHE_TTL_SECONDS=30

REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=vpn_bot
USER_CACHE_TTL_SECONDS=60

SCHEDULER_ENABLED=true
SCHEDULER_LEADER_LOCK_TTL_SECONDS=90
BROADCAST_BATCH_SIZE=200
BROADCAST_SEND_DELAY_SECONDS=0.05
BROADCAST_RETRY_ATTEMPTS=3
BROADCAST_RETRY_BASE_DELAY_SECONDS=1.0
BROADCAST_NOTIFY_POLICY=always

# =========================
# Trial / support / UI toggles
# =========================
TRIAL_DURATION_HOURS=24
TRIAL_DURATION_DAYS=1
TRIAL_TRAFFIC_GB=5
TRIAL_DEVICE_COUNT=1

SHOW_SUBSCRIPTION_COPY_BUTTON=true
SHOW_SUBSCRIPTION_PAGE_BUTTON=true

SUPPORT_TICKET_AUTO_CLOSE_HOURS=48
SUPPORT_MAX_MEDIA_BYTES=5242880
SUPPORT_ALLOWED_MEDIA_TYPES=["photo","video","document","audio","voice","video_note","animation","sticker"]

# =========================
# Legal / policy links
# =========================
RULES_SERVICE_URL=https://bot.svoivpn.xyz/rules
RULES_OF_USE_URL=https://bot.svoivpn.xyz/terms
RULES_PRIVACY_URL=https://bot.svoivpn.xyz/privacy


BROADCAST_MAX_CONCURRENT=15